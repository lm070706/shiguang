<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <!-- 顶部导航栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@android:color/white"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="拾光圈笔记"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <!-- 主容器：使用CoordinatorLayout处理键盘 -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- 外层ScrollView -->
        <ScrollView
            android:id="@+id/outer_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:layout_gravity="top">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 笔记主体区域 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@android:color/white"
                    android:padding="20dp">

                    <!-- 笔记标题 -->
                    <TextView
                        android:id="@+id/tv_note_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="6dp"/>

                    <!-- 作者和时间 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_avatar_default"/>

                        <TextView
                            android:id="@+id/tv_note_author"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textSize="14sp"
                            android:textColor="@android:color/darker_gray"/>

                        <TextView
                            android:id="@+id/tv_note_create_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textSize="12sp"
                            android:textColor="@android:color/darker_gray"/>
                    </LinearLayout>

                    <!-- 笔记正文 -->
                    <TextView
                        android:id="@+id/tv_note_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textSize="16sp"
                        android:lineSpacingExtra="8dp"
                        android:textColor="@android:color/black"/>

                    <!-- 笔记图片展示区 -->
                    <HorizontalScrollView
                        android:id="@+id/horizontalScrollView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:scrollbars="horizontal">

                        <LinearLayout
                            android:id="@+id/ll_note_images"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="4dp"/>
                    </HorizontalScrollView>

                    <!-- 点赞和评论统计 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:paddingTop="16dp">

                        <!-- 点赞 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/iv_note_like"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_like"
                                android:clickable="true"
                                android:focusable="true"/>

                            <TextView
                                android:id="@+id/tv_note_like_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textSize="14sp"/>
                        </LinearLayout>

                        <!-- 评论 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/iv_note_comment"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/iv_comment"
                                android:clickable="true"
                                android:focusable="true"/>

                            <TextView
                                android:id="@+id/tv_note_comment_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textSize="14sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 评论区展开/收起按钮 -->
                    <LinearLayout
                        android:id="@+id/ll_comment_toggle"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:background="#F0F0F0"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:id="@+id/tv_comment_toggle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="查看评论区 (0)"
                            android:textSize="16sp"
                            android:textColor="@color/blue"/>

                        <ImageView
                            android:id="@+id/iv_comment_arrow"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/arrow_down_float"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- 评论区容器（默认折叠，在笔记详情下方） -->
                <LinearLayout
                    android:id="@+id/ll_comment_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#F5F5F5"
                    android:visibility="gone">

                    <!-- 评论区标题 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp"
                        android:text="评论区"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"/>

                    <!-- 评论列表 -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_note_comments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="200dp"
                        android:maxHeight="400dp"
                        android:padding="8dp"/>

                    <!-- 空评论提示 -->
                    <TextView
                        android:id="@+id/tv_comment_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="暂无评论，快来抢沙发~"
                        android:gravity="center"
                        android:textSize="16sp"
                        android:textColor="@android:color/darker_gray"
                        android:visibility="gone"
                        android:padding="32dp"/>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- 评论输入栏（固定在底部） -->
    <LinearLayout
        android:id="@+id/ll_input_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:elevation="8dp">
        <Button
            android:id="@+id/btn_cancel_reply"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:text="取消"
            android:textSize="14sp"
            android:paddingHorizontal="10dp"
            android:visibility="gone"
        android:background="@color/blue"
        android:textColor="@color/black"/>
        <EditText
            android:id="@+id/et_comment_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="40dp"
            android:maxLines="3"
            android:background="@drawable/shape_edittext_bg"
            android:hint="输入评论内容..."
            android:paddingHorizontal="12dp"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/btn_send_comment"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@color/blue"
            android:text="发送"
            android:textColor="@color/white"
            android:textSize="14sp"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>
</LinearLayout>